
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shared EIA Skill Schema",
  "description": "Input/output schema for the eia-report-automation skill and reusable sub-skills.",
  "input_schema": {
    "type": "object",
    "required": ["project_name", "location", "sector", "scale", "activities", "jurisdiction"],
    "properties": {
      "project_name": {"type": "string"},
      "location": {
        "type": "object",
        "required": ["country"],
        "properties": {
          "country": {"type": "string"},
          "region": {"type": "string"},
          "coordinates": {
            "type": "object",
            "properties": {"lat": {"type": "number"}, "lon": {"type": "number"}}
          }
        }
      },
      "sector": {"type": "string"},
      "scale": {"type": "string", "enum": ["small", "medium", "large"]},
      "activities": {"type": "array", "items": {"type": "string"}},
      "jurisdiction": {"type": "string"},
      "sensitive_receptors": {"type": "array", "items": {"type": "string"}},
      "baseline_data": {"type": "string"},
      "regulatory_regime": {"type": "string"},
      "goal": {"type": "string"}
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["executive_summary", "inputs_and_assumptions", "multi_dimensional_score", "findings", "improvement_roadmap", "sources_and_limitations", "disclaimer"],
    "properties": {
      "executive_summary": {
        "type": "object",
        "required": ["verdict", "headline_score"],
        "properties": {"verdict": {"type": "string"}, "headline_score": {"type": "string"}}
      },
      "inputs_and_assumptions": {
        "type": "object",
        "required": ["provided", "assumed", "missing"],
        "properties": {
          "provided": {"type": "object"},
          "assumed": {"type": "array", "items": {"type": "string"}},
          "missing": {"type": "array", "items": {"type": "string"}}
        }
      },

      "multi_dimensional_score": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["dimension", "score", "framework", "evidence"],
          "properties": {
            "dimension": {"type": "string", "enum": ["air", "water", "soil", "biodiversity", "social", "cumulative"]},
            "score": {"type": "string", "enum": ["A", "B", "C", "D", "E"]},
            "framework": {"type": "string"},
            "evidence": {"type": "array", "items": {"type": "string"}},
            "confidence": {"type": "string", "enum": ["high", "medium", "low"]}
          }
        }
      },
      "findings": {
        "type": "object",
        "required": ["strengths", "risks", "gaps"],
        "properties": {
          "strengths": {"type": "array", "items": {"type": "string"}},
          "risks": {"type": "array", "items": {"type": "string"}},
          "gaps": {"type": "array", "items": {"type": "string"}}
        }
      },
      "improvement_roadmap": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["action", "tier", "effort", "impact", "priority_rank", "timeline", "evidence"],
          "properties": {
            "action": {"type": "string"},
            "tier": {"type": "string", "enum": ["avoid", "minimize", "restore", "offset"]},
            "effort": {"type": "string", "enum": ["low", "medium", "high"]},
            "impact": {"type": "string", "enum": ["low", "medium", "high"]},
            "priority_rank": {"type": "number"},
            "timeline": {"type": "string"},
            "evidence": {"type": "array", "items": {"type": "string"}}
          }
        }
      },
      "sources_and_limitations": {
        "type": "object",
        "required": ["sources", "limitations"],
        "properties": {
          "sources": {"type": "array", "items": {"type": "string"}},
          "limitations": {"type": "array", "items": {"type": "string"}}
        }
      },
      "disclaimer": {"type": "string"}
    }
  }
}
